# =============================================================================
# Python / Flask .gitignore
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment variables (contains secrets)
.env

# SQLite database files
*.db
*.sqlite3

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Coverage / testing
htmlcov/
.coverage
.pytest_cache/
