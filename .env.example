# =============================================================================
# URL Shortener - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
#
# DATABASE_URL: Connection string for the database.
#   - SQLite (local dev):  sqlite:///urls.db
#   - MySQL (production):  mysql+pymysql://user:password@host:3306/dbname
#
# SECRET_KEY: A random secret used by Flask for session signing.
#   Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
#
# BASE_URL: The public-facing base URL for constructing short links.
#   - Local dev:   http://localhost:5000
#   - Production:  https://yourdomain.com
# =============================================================================

DATABASE_URL=sqlite:///urls.db
SECRET_KEY=change-me-to-a-random-secret
BASE_URL=http://localhost:5000
